[delta]
    syntax-theme = inklight
    line-numbers-minus-style = "#b61e00"
    line-numbers-plus-style = "#387200"
    line-numbers-zero-style = "#6e6e6e"
    minus-style = "syntax #ffe0da"
    minus-emph-style = "syntax #ffcdc2"
    plus-style = "syntax #dcefd3"
    plus-emph-style = "syntax #c8e4ba"
